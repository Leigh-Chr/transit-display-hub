# =============================================================================
# transit-display-hub — runtime environment variables
#
# Copy to .env and fill in. Variables marked REQUIRED have no fallback;
# the backend refuses to boot without them. Variables marked DEV-ONLY are
# safe defaults for the dev profile but MUST be set explicitly in prod /
# kiosk deploys (the bracketed values document the production posture).
# =============================================================================

# ---- Database (REQUIRED in prod / kiosk) ------------------------------------
POSTGRES_DB=transitdb
POSTGRES_USER=transit
# The kiosk Docker Compose file expects POSTGRES_PASSWORD (fail-fast if
# unset). Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=change-me-to-a-secure-password
DATABASE_PASSWORD=change-me-to-a-secure-password
# Defaults to jdbc:postgresql://localhost:5432/transit (prod) or
# jdbc:postgresql://postgres:5432/transit (kiosk compose). Override only
# when the host/port/database differs.
# DATABASE_URL=jdbc:postgresql://db.internal:5432/transit
# DATABASE_USER=transit  # alias when DATABASE_URL points at a managed DB

# ---- JWT (REQUIRED in every profile, including dev) -------------------------
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-256-bit-secret-key-at-least-32-chars
# JWT_ISSUER=transit-display-hub          # default
# JWT_AUDIENCE=transit-display-hub-admin  # default
# JWT_REFRESH_EXPIRATION_DAYS=14          # default

# ---- HTTP cookies (DEV-ONLY defaults — review before production) ------------
# Cookie names are stable; flip Secure to true behind HTTPS, narrow Domain.
# AUTH_ACCESS_COOKIE_NAME=ACCESS_TOKEN
# AUTH_REFRESH_COOKIE_NAME=REFRESH_TOKEN
# AUTH_COOKIE_SECURE=true                 # default; dev profile overrides to false
# AUTH_COOKIE_SAME_SITE=Strict            # default
# AUTH_COOKIE_DOMAIN=                     # default empty = current host

# ---- CORS (REQUIRED in prod) ------------------------------------------------
# Comma-separated allowlist. The localhost defaults work for the dev profile
# but every legitimate browser origin in prod must be listed explicitly.
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# ---- Login rate limit (defaults: 5 attempts / 5 min in prod) ----------------
# APP_SECURITY_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
# APP_SECURITY_LOGIN_RATE_LIMIT_WINDOW_MINUTES=5

# ---- Refresh rate limit (defaults: 30 rotations / 1 min) --------------------
# Pinned above legitimate rotation cadence (access token ≈ 15 min → ~4/h per
# tab) but tight enough to spot a stolen-token brute-force loop.
# APP_SECURITY_REFRESH_RATE_LIMIT_MAX_ATTEMPTS=30
# APP_SECURITY_REFRESH_RATE_LIMIT_WINDOW_MINUTES=1

# ---- Trusted proxies (X-Forwarded-For trust list, shared by all rate limits) -
# Accepts literal IPs and CIDR blocks. Empty = TCP peer is always the source
# of truth.
# APP_SECURITY_TRUSTED_PROXIES=10.0.0.0/8,192.168.0.0/16

# ---- Refresh token housekeeping ---------------------------------------------
# APP_AUTH_REFRESH_TOKEN_PURGE_CRON=0 30 4 * * *   # daily 04:30 (default)

# ---- GTFS data loader (DEV: seeds at boot; PROD: leave empty) ---------------
# DATA_LOADER_SOURCE=gtfs
# DATA_LOADER_GTFS_URL=https://data.mobilites-m.fr/api/gtfs/SEM
# DATA_LOADER_GTFS_NETWORK_NAME=M Réso (Grenoble)
# DATA_LOADER_GTFS_ATTRIBUTION=SMMAG / M Réso — ODbL

# ---- GTFS-Realtime polling crons (defaults shown) ---------------------------
# APP_GTFS_RT_ALERTS_POLL_CRON=5,35 * * * * *
# APP_GTFS_RT_TRIP_UPDATES_POLL_CRON=15,45 * * * * *
# APP_GTFS_RT_VEHICLE_POSITIONS_POLL_CRON=0,20,40 * * * * *

# ---- GTFS static refresh (default: daily 04:00, after the RT crons drain) ---
# APP_DATA_LOADER_GTFS_REFRESH_CRON=0 0 4 * * *

# ---- GTFS validation (MobilityData gtfs-validator) --------------------------
# Disable in prod only if the validator becomes a bottleneck on a large feed.
# APP_GTFS_VALIDATION_ENABLED=true
# Defaults to ${java.io.tmpdir}/gtfs-validation. Override to a persistent
# volume so the JSON/HTML reports survive container restarts.
# APP_GTFS_VALIDATION_REPORT_BASE_DIR=/var/lib/transit/gtfs-validation

# ---- Password hashing (BCrypt cost factor) ----------------------------------
# 12 ≈ 250 ms on a modern CPU. Raise to 13/14 on faster hardware to keep the
# auth hot path balanced against brute-force resistance.
# APP_SECURITY_BCRYPT_STRENGTH=12

# ---- Locale & time zone -----------------------------------------------------
# APP_TIMEZONE=Europe/Paris
# APP_TRANSLATIONS_PREFERRED_LANGUAGE=fr
