{
  "name": "transit-display-hub",
  "version": "1.25.0",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --watch=false --coverage --coverage-reporters=html --coverage-reporters=lcov --coverage-reporters=json-summary --coverage-reporters=text-summary",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "lint": "eslint \"src/**/*.ts\" \"src/**/*.html\" \"e2e/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"src/**/*.html\" \"e2e/**/*.ts\" --fix",
    "knip": "knip"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/material": "^21.2.10",
    "@angular/platform-browser": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@fontsource/inter": "^5.2.8",
    "@jsverse/transloco": "^8.3.0",
    "@stomp/stompjs": "^7.3.0",
    "material-icons": "^1.13.14",
    "ngxtension": "^7.2.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.3.0",
    "jsdom": "^29.1.1",
    "knip": "^6.14.1",
    "typescript": "~6.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.0.18"
  }
}
