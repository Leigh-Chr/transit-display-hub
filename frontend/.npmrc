# Angular 21.2 build (@angular/build) declares a strict peer dep
# `typescript@">=5.9 <6.0"`, while this project pins TypeScript ~6.0
# to track the latest stable line. The TypeScript 6.x runtime works
# fine with the Angular toolchain in practice, but npm refuses to
# install without --legacy-peer-deps.
#
# Last verified 2026-05-18 against @angular/build@21.2.11 — still
# requires --legacy-peer-deps. Re-evaluate once Angular bumps its
# peer range to include TypeScript 6.x (likely Angular 21.3+).
legacy-peer-deps=true
