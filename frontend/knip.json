{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/test-setup.ts"],
  "project": ["src/**/*.ts"],
  "ignoreDependencies": [
    "@fontsource/inter",
    "material-icons"
  ],
  "rules": {
    "types": "off",
    "enumMembers": "off"
  },
  "angular": {
    "entry": [
      "src/app/**/*.component.ts",
      "src/app/**/*.service.ts",
      "src/app/**/*.guard.ts",
      "src/app/**/*.interceptor.ts",
      "src/app/**/*.pipe.ts",
      "src/app/**/*.directive.ts"
    ]
  }
}
