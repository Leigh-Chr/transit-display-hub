{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/test-setup.ts"],
  "project": ["src/**/*.ts"],
  "ignoreDependencies": [
    "@vitest/browser",
    "@fontsource/inter",
    "material-icons"
  ],
  "angular": {
    "entry": [
      "src/app/**/*.component.ts",
      "src/app/**/*.service.ts",
      "src/app/**/*.guard.ts",
      "src/app/**/*.interceptor.ts",
      "src/app/**/*.pipe.ts",
      "src/app/**/*.directive.ts"
    ]
  }
}
