echo "Running pre-push checks..."

# Light by default — lint + compile only. CI re-runs the full test
# suite and the rest of the gradle check chain (jacoco, spotbugs, pmd,
# archunit) on every push, so duplicating it client-side just slows
# small commits down and discourages frequent pushes. Set PUSH_FULL=1
# in the environment for the original full behaviour, e.g.:
#   PUSH_FULL=1 git push

REMOTE_SHA=$(git rev-parse @{u} 2>/dev/null || git rev-parse HEAD~1)
CHANGED_FILES=$(git diff --name-only "$REMOTE_SHA"..HEAD)

FRONTEND_CHANGED=$(echo "$CHANGED_FILES" | grep -c '^frontend/' || true)
BACKEND_CHANGED=$(echo "$CHANGED_FILES" | grep -c '^backend/' || true)

PIDS=""
EXIT_CODE=0

if [ "$FRONTEND_CHANGED" -gt 0 ]; then
  if [ "${PUSH_FULL:-0}" = "1" ]; then
    echo "  -> PUSH_FULL=1, running frontend lint + knip + tests..."
    (cd frontend && npm run lint && npm run knip && npm test) &
  else
    echo "  -> Running frontend lint (set PUSH_FULL=1 for full suite)..."
    (cd frontend && npm run lint) &
  fi
  PIDS="$PIDS $!"
fi

if [ "$BACKEND_CHANGED" -gt 0 ]; then
  if [ "${PUSH_FULL:-0}" = "1" ]; then
    echo "  -> PUSH_FULL=1, running backend check (test + jacoco + spotbugs + pmd)..."
    (cd backend && ./gradlew check --no-daemon -q) &
  else
    echo "  -> Compiling backend main + tests (set PUSH_FULL=1 for full check)..."
    (cd backend && ./gradlew compileJava compileTestJava --no-daemon -q) &
  fi
  PIDS="$PIDS $!"
fi

if [ -z "$PIDS" ]; then
  echo "  -> No frontend/backend changes, skipping tests."
  exit 0
fi

for PID in $PIDS; do
  wait "$PID" || EXIT_CODE=1
done

if [ "$EXIT_CODE" -ne 0 ]; then
  echo "Pre-push checks FAILED. Push aborted."
  exit 1
fi

echo "Pre-push checks passed."
